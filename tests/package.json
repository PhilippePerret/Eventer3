{
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:unit": "clear;clear;node --test specs/unit/**/*.test.js",
    "test:ruby:tdd": "clear;clear;ruby ruby/_tdd/*",
    "test:ruby": "clear;clear;ruby ruby/**/*",
    "test:unit:tdd": "clear;clear;node --test specs/unit/_tdd/*.test.js",
    "test:e2e": "clear;clear;playwright test",
    "test:e2e:tdd": "clear;clear;playwright test -- e2e/_tdd",
    "test:all": "clear;clear;ruby ruby/**/*;playwright test;node --test specs/unit/**/*.test.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1"
  }
}
